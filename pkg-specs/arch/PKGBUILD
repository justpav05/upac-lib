# Maintainer: justpav05 <aksenovpaveldmitrievich@gmail.com>
pkgname=upac
pkgver=0.1.0
pkgrel=1
pkgdesc="A modular Linux package manager with OStree integration"
arch=('x86_64')
url="https://github.com/justpav05/upac"
license=('TBD')
depends=(
    'ostree'
    'glib2'
    'libarchive'
)
options=('!strip')

# Не скачиваем исходники — используем уже собранные файлы из pkg/arch/root/
source=()
sha256sums=()

package() {
    # Бинарь
    install -Dm755 "${srcdir}/../root/usr/bin/upac" \
        "${pkgdir}/usr/bin/upac"

    # Библиотеки
    install -Dm755 "${srcdir}/../root/usr/lib/libupac.so" \
        "${pkgdir}/usr/lib/libupac.so"

    install -Dm755 "${srcdir}/../root/usr/lib/libupac-backend-arch.so" \
        "${pkgdir}/usr/lib/libupac-backend-arch.so"

    install -Dm755 "${srcdir}/../root/usr/lib/libupac-backend-rpm.so" \
        "${pkgdir}/usr/lib/libupac-backend-rpm.so"

    # Пример конфига
    install -Dm644 "${srcdir}/../root/etc/upac/config.toml.example" \
        "${pkgdir}/etc/upac/config.toml.example"
}
