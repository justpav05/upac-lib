# Maintainer: justpav05 <aksenovpaveldmitrievich@gmail.com>
pkgname=upac
pkgver=0.1.0
pkgrel=1
pkgdesc="A modular Linux package manager with OStree integration"
arch=('x86_64')
url="https://github.com/justpav05/upac"
license=('GNUv3')
backup=('etc/upac/config.toml')
depends=(
    'ostree'
    'glib2'
    'libarchive'
)
options=('!strip')

source=()
sha256sums=()

package() {
    # Bin
    install -Dm755 "${srcdir}/../root/usr/bin/upac" "${pkgdir}/usr/bin/upac"

    # Libs
    install -Dm755 "${srcdir}/../root/usr/lib/libupac.so" "${pkgdir}/usr/lib/libupac.so"
    install -Dm755 "${srcdir}/../root/usr/lib/libupac-arch.so" "${pkgdir}/usr/lib/libupac-arch.so"
    install -Dm755 "${srcdir}/../root/usr/lib/libupac-rpm.so" "${pkgdir}/usr/lib/libupac-rpm.so"
    install -Dm755 "${srcdir}/../root/usr/lib/libupac-deb.so" "${pkgdir}/usr/lib/libupac-deb.so"

    # Config
    install -Dm644 "${srcdir}/../root/etc/upac/config.toml"  "${pkgdir}/etc/upac/config.toml"
}
